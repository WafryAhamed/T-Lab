APP_NAME=TLab
APP_ENV=production
APP_KEY=-
APP_DEBUG=false
APP_URL=https://your-railway-backend-url.up.railway.app
FRONTEND_URL=https://your-vercel-frontend-url.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=pgsql
# For local development, set separate vars:
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=t_lab
DB_USERNAME=postgres
DB_PASSWORD=replace_me
# Railway provides DATABASE_URL automatically from the PostgreSQL plugin.
# Laravel reads it via DATABASE_URL automatically. No manual host/port/db config needed on Railway.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000,::1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="T Lab"
RESEND_API_KEY=replace_me

JWT_SECRET=replace_me
JWT_TTL=60
JWT_REMEMBER_TTL=10080
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=0

OPENROUTER_API_KEY=

VITE_APP_NAME="${APP_NAME}"
